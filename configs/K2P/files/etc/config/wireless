
config wifi-device 'ra0'
	option type 'mt_dbdc'
	option hwmode '11g'
	option country 'US'
	option txburst '0'
	option smart '0'
	option channel '6'
	option htmode 'HT20'

config wifi-iface 'default_ra0'
	option device 'ra0'
	option network 'lan'
	option mode 'ap'
	option ssid 'OpenWrt-2g'
	option encryption 'psk2'
	option key 'password'

config wifi-device 'rax0'
	option type 'mt_dbdc'
	option hwmode '11a'
	option country 'US'
	option txburst '0'
	option smart '0'
	option channel '149'
	option htmode 'VHT80'

config wifi-iface 'default_rax0'
	option device 'rax0'
	option network 'lan'
	option mode 'ap'
	option ssid 'OpenWrt-5g'
	option encryption 'psk2'
	option key 'password'

